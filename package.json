        "@types/fs-extra": "^11.0.4",
        "@types/node": "^22.10.7",
        "@types/webpack-env": "^1.18.8",
        "@types/yazl": "^3.3.0",
        "@types/zip-webpack-plugin": "^3.0.6",
        "blockly": "^11.2.0",
        "copy-webpack-plugin": "^13.0.0",
        "cross-env": "^10.0.0",
        "css-loader": "^7.1.2",
        "eslint": "^9.16.0",
        "fs-extra": "^11.3.1",
        "globals": "^17.3.0",
        "html-webpack-plugin": "^5.6.3",
        "jiti": "^2.5.1",
        "npm-run-all": "^4.1.5",
        "raw-loader": "^4.0.2",
        "rimraf": "^6.0.1",
        "style-loader": "^4.0.0",
        "ts-loader": "^9.5.1",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.16.0",
        "url-loader": "^4.1.1",
        "webpack": "^5.96.1",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^5.1.0",
        "webpack-merge": "^6.0.1",
        "webpack-sources": "*",
        "webpackbar": "^7.0.0",
        "yazl": "^3.3.1",
        "zip-webpack-plugin": "^4.0.3"
    },
    "dependencies": {
        "@types/md5": "^2.3.6",
